# ERP Integrations
ADMINHUB_BASE_URL=https://api.adminhub.example.com
ADMINHUB_API_KEY=your_adminhub_key_here
NEXUS_BASE_URL=https://api.nexus.example.com
NEXUS_ERP_API_KEY=your_nexus_key_here

# Payment Gateway (Asaas)
ASAAS_API_KEY=your_asaas_api_key_here
ASAAS_API_URL=https://api.asaas.com/v3 # Ou https://sandbox.asaas.com/v3 para testes
AZAS_WEBHOOK_TOKEN=your_webhook_token_here

# Firebase Admin (Server-side)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_SECURE=false
COMPANY_EMAIL_SENDER=suporte@dicasbyale.com

# App Configuration
PUBLIC_APP_URL=https://dicasbyale.com

# DHL Carrier Integration (Sandbox)
DHL_API_KEY=
DHL_API_SECRET=
DHL_BASE_URL=https://api-sandbox.dhl.com
